rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return signedIn() && request.auth.token.admin == true;
    }

    function ownsExistingDocument() {
      return signedIn() && resource.data.userId == request.auth.uid;
    }

    function ownsIncomingDocument() {
      return signedIn() && request.resource.data.userId == request.auth.uid;
    }

    function ownsGoal(goalId) {
      return signedIn()
        && get(/databases/$(database)/documents/goals/$(goalId)).data.userId
          == request.auth.uid;
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId)
                    && request.resource.data.role == 'user'
                    && request.resource.data.status == 'active';
      allow update: if isOwner(userId)
                    && request.resource.data.diff(resource.data).affectedKeys()
                      .hasOnly([
                        'fullName',
                        'birthday',
                        'phoneNumber',
                        'avatarUrl',
                        'updatedAt',
                        'lastLoginAt',
                        'onboardingCompleted'
                      ]);
      allow delete: if false;

      match /wallets/{walletId} {
        allow read, write: if isOwner(userId);

        match /transactions/{transactionId} {
          allow read, write: if isOwner(userId);
        }
      }
    }

    match /categories/{categoryId} {
      allow read, delete: if ownsExistingDocument();
      allow create: if ownsIncomingDocument();
      allow update: if ownsExistingDocument() && ownsIncomingDocument();
    }

    match /budgets/{budgetId} {
      allow read, delete: if ownsExistingDocument();
      allow create: if ownsIncomingDocument();
      allow update: if ownsExistingDocument() && ownsIncomingDocument();
    }

    match /goals/{goalId} {
      allow read, delete: if ownsExistingDocument();
      allow create: if ownsIncomingDocument();
      allow update: if ownsExistingDocument() && ownsIncomingDocument();
    }

    match /goal_contributions/{contributionId} {
      allow read, delete: if ownsGoal(resource.data.goalId);
      allow create: if ownsGoal(request.resource.data.goalId);
      allow update: if ownsGoal(resource.data.goalId)
                    && ownsGoal(request.resource.data.goalId);
    }

    match /recurring_transactions/{transactionId} {
      allow read, delete: if ownsExistingDocument();
      allow create: if ownsIncomingDocument();
      allow update: if ownsExistingDocument() && ownsIncomingDocument();
    }

    match /debts/{debtId} {
      allow read, delete: if ownsExistingDocument();
      allow create: if ownsIncomingDocument();
      allow update: if ownsExistingDocument() && ownsIncomingDocument();
    }

    match /debt_payments/{paymentId} {
      allow read, delete: if ownsExistingDocument();
      allow create: if ownsIncomingDocument();
      allow update: if ownsExistingDocument() && ownsIncomingDocument();
    }

    match /default_categories/{categoryId} {
      allow read: if isAdmin()
                  || (signedIn() && resource.data.isActive == true);
      allow create, update: if isAdmin();
      allow delete: if false;
    }

    match /system_notifications/{notificationId} {
      allow read: if signedIn();
      allow create, update, delete: if isAdmin();
    }

    match /app_config/{configId} {
      allow read: if configId == 'general';
      allow create, update: if configId == 'general' && isAdmin();
      allow delete: if false;
    }

    match /admin_audit_logs/{logId} {
      allow read, create: if isAdmin();
      allow update, delete: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
